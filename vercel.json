{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "desk.fredheimtech.com" }],
      "destination": "https://trovanttalent.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.fredheimtech.com" }],
      "destination": "https://trovanttalent.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fredheimtech.com" }],
      "destination": "https://trovanttalent.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.fredheimdesk.com" }],
      "destination": "https://trovanttalent.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fredheimdesk.com" }],
      "destination": "https://trovanttalent.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/)(?!.*\\.html$).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/talent-billing",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/talent-notify?job=realtime",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/talent-notify?job=daily",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/talent-notify?job=weekly",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/talent-candidates?action=reengagement-job",
      "schedule": "0 9 * * *"
    }
  ]
}
